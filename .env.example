NODE_ENV=production
PORT=5173

# PostgreSQL
POSTGRES_DB=marra_transportes
POSTGRES_USER=marra_user
POSTGRES_PASSWORD=SENHA_FORTE
DATABASE_URL=postgres://marra_user:SENHA_FORTE@marra-db:5432/marra_transportes

# Gere um valor longo e unico em producao.
JWT_SECRET=troque-este-segredo-por-um-valor-grande

# Primeiro administrador do sistema.
ADMIN_EMAIL=admin@marra.com
ADMIN_PASSWORD=troque-esta-senha

# Envio de comprovantes por e-mail.
# Exemplo HostGator/cPanel: SMTP_HOST=mail.seudominio.com.br, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# E-mails internos da Marra que recebem todo comprovante. Separe multiplos por virgula.
MARRA_NOTIFICATION_EMAILS=
